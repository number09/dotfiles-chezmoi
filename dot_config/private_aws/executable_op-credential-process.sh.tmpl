#!/bin/bash

# 1Passwordから認証情報を取得してAWS credential_process形式で出力。
# item 名 / account は機密(アカウント識別子)のためリポジトリに残さず、
# chezmoi init 時の手入力 (.aws.opItem / .aws.opAccount) で展開する。
op item get "{{ .aws.opItem }}" --account "{{ .aws.opAccount }}" --format json | jq '{
  Version: 1,
  AccessKeyId: (.fields[] | select(.label == "access key id") | .value),
  SecretAccessKey: (.fields[] | select(.label == "secret access key") | .value),
  Expiration: "2099-12-31T23:59:59Z",
  SessionToken: ""
}'
